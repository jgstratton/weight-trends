{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/app/node_modules/.bin/vite",
      "runtimeArgs": ["dev"],
      "cwd": "${workspaceFolder}/app",
      "envFile": "${workspaceFolder}/.env",
      "sourceMaps": true,
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ],
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    }
  ]
}
